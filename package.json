{
  "name": "the-fixer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:watch": "vitest tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.test.ts",
    "test:e2e:bot": "playwright test tests/e2e/input-bot.test.ts",
    "test:e2e:perf": "playwright test tests/e2e/perf.test.ts",
    "test:visual:baseline": "node tests/visual/baseline.mjs",
    "test:visual:compare": "node tests/visual/compare.mjs",
    "test:visual:baseline:force": "node tests/visual/baseline.mjs --force",
    "hooks:install": "bash scripts/install-hooks.sh"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.2",
    "@react-three/rapier": "^1.5.0",
    "express": "^4.21.0",
    "howler": "^2.2.4",
    "postprocessing": "^6.36.3",
    "r3f-perf": "^7.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.168.0",
    "tone": "^15.0.4",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@playwright/test": "^1.48.2",
    "@types/express": "^4.17.21",
    "@types/howler": "^2.2.11",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.168.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.8.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "eslint": "$eslint",
    "zustand": "$zustand"
  }
}
